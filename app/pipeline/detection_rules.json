{
  "_comment": "Shield PII Detection Rules — edit this file to tune detection without code changes.",
  "_version": "1.1.0",
  "_docs": "Each rule creates a Presidio PatternRecognizer. 'context' words boost confidence when found nearby.",

  "rules": [
    {
      "name": "DE_IBAN_Fallback",
      "entity_type": "IBAN_CODE",
      "description": "German IBAN by shape (DE + 20 digits). Catches typed/OCR IBANs that fail the ISO-13616 mod-97 checksum, which Presidio's IbanRecognizer silently rejects (-> verbatim leak). Lower score than the validating recognizer.",
      "patterns": [
        {
          "name": "de_iban_shape",
          "regex": "\\bDE\\d{2}(?:\\s?\\d{4}){4}\\s?\\d{2}\\b",
          "score": 0.6
        }
      ],
      "context": ["iban", "konto", "bank", "überweisung", "ueberweisung", "bankverbindung", "zahlung"]
    },
    {
      "name": "IPv6_Compressed",
      "entity_type": "IP_ADDRESS",
      "description": "Full + compressed (::) IPv6. Presidio's IpRecognizer truncates compressed forms to the prefix (2001:db8:: only), leaking the tail. Boundary guards (not \\b) avoid MAC addresses / HH:MM:SS times; requiring >=1 hex group avoids a bare '::' scope operator.",
      "patterns": [
        {
          "name": "ipv6_full_or_compressed",
          "regex": "(?<![0-9A-Za-z:])(?:(?:[0-9A-Fa-f]{1,4}:){7}[0-9A-Fa-f]{1,4}|(?:[0-9A-Fa-f]{1,4}(?::[0-9A-Fa-f]{1,4})*::(?:[0-9A-Fa-f]{1,4}(?::[0-9A-Fa-f]{1,4})*)?|::[0-9A-Fa-f]{1,4}(?::[0-9A-Fa-f]{1,4})*))(?![0-9A-Za-z:])",
          "score": 0.6
        }
      ],
      "context": ["ip", "ipv6", "adresse", "host", "gateway"]
    },
    {
      "name": "DE_StreetWithNumber",
      "entity_type": "LOCATION",
      "description": "German street + house number",
      "patterns": [
        {
          "name": "street_suffix_number",
          "regex": "\\b(?:[\\w\\u00C0-\\u024F]+-)*[\\w\\u00C0-\\u024F]*(?:stra[sß]e|strasse|str\\.|gasse|weg|allee|platz|ring|damm|ufer|chaussee|heide|hof|berg|tal|feld|grund|au|aue)\\.? \\d{1,4} ?[a-zA-Z]?\\b",
          "score": 0.9
        }
      ],
      "context": ["adresse", "anschrift", "wohnhaft", "wohnt"]
    },
    {
      "name": "DE_StreetName",
      "entity_type": "LOCATION",
      "description": "German street name without number",
      "patterns": [
        {
          "name": "street_suffix_only",
          "regex": "\\b(?:[\\w\\u00C0-\\u024F]+-)*[\\w\\u00C0-\\u024F]*(?:stra[sß]e|strasse|str\\.|gasse|weg|allee|platz|ring|damm|ufer|chaussee|heide|hof|berg|tal|feld|grund|au|aue)\\.?\\b",
          "score": 0.7
        }
      ],
      "context": ["adresse", "anschrift", "wohnhaft", "wohnt", "straße"]
    },
    {
      "name": "DE_PLZCity",
      "entity_type": "LOCATION",
      "description": "German postal code + city",
      "patterns": [
        {
          "name": "plz_city",
          "regex": "\\b\\d{5}\\s+[A-ZÄÖÜ][\\w\\u00C0-\\u024F]+\\b",
          "score": 0.85
        }
      ],
      "context": ["ort", "stadt", "plz", "postleitzahl"]
    },
    {
      "name": "DE_PLZ",
      "entity_type": "LOCATION",
      "description": "Standalone German postal code (5 digits, needs context)",
      "patterns": [
        {
          "name": "plz_standalone",
          "regex": "\\b\\d{5}\\b",
          "score": 0.4
        }
      ],
      "context": ["plz", "postleitzahl", "ort", "stadt", "adresse", "anschrift"]
    },
    {
      "name": "Phone_International",
      "entity_type": "PHONE_NUMBER",
      "description": "International phone numbers (+49, +44, +43, +41, +33, +31, +46, +81, etc.)",
      "patterns": [
        {
          "name": "phone_intl_plus",
          "regex": "\\+\\d{1,3}[\\s.-]?\\(?\\d{1,5}\\)?[\\s.-]?[\\d\\s.-]{4,12}\\d",
          "score": 0.85
        },
        {
          "name": "de_phone_local",
          "regex": "\\b0\\d{2,4}[\\s/.-]\\d{4,8}[\\s/.-]?\\d{0,5}\\b",
          "score": 0.7
        }
      ],
      "context": ["telefon", "tel", "fax", "mobil", "handy", "festnetz", "durchwahl", "rückruf", "phone", "mobile"]
    },
    {
      "name": "DE_SteuerID",
      "entity_type": "DE_TAX_ID",
      "description": "German tax identification number (Steuer-ID, 11 digits)",
      "patterns": [
        {
          "name": "steuer_id_spaced",
          "regex": "\\b\\d{2}\\s?\\d{3}\\s?\\d{3}\\s?\\d{3}\\b",
          "score": 0.5
        }
      ],
      "context": ["steuer", "steuer-id", "identifikationsnummer", "tin", "finanzamt"]
    },
    {
      "name": "DE_Sozialversicherung",
      "entity_type": "DE_SOCIAL_SECURITY",
      "description": "German social security number (12 chars: NN DDMMYY L NNN)",
      "patterns": [
        {
          "name": "sv_nr",
          "regex": "\\b\\d{2}\\s?\\d{6}\\s?[A-Z]\\s?\\d{3}\\b",
          "score": 0.85
        }
      ],
      "context": ["sozialversicherung", "sv-nr", "sozialversicherungsnr", "rentenversicherung"]
    },
    {
      "name": "DE_Personalausweis",
      "entity_type": "DE_ID_CARD",
      "description": "German ID card number (9-10 chars alphanumeric)",
      "patterns": [
        {
          "name": "perso_nr",
          "regex": "\\b[A-Z][A-Z0-9]\\d{7}[A-Z]?\\b",
          "score": 0.5
        }
      ],
      "context": ["personalausweis", "ausweis", "ausweisn", "perso", "identit"]
    },
    {
      "name": "DE_OrgSuffix",
      "entity_type": "ORGANIZATION",
      "description": "Text ending with German legal suffix (GmbH, AG, etc.)",
      "patterns": [
        {
          "name": "org_legal_suffix",
          "regex": "[A-ZÄÖÜ][\\w\\u00C0-\\u024F]+(?:(?: [&] | )[A-ZÄÖÜa-zäöü][\\w\\u00C0-\\u024F]+){0,7} (?:GmbH|mbH|AG|e\\.? ?V\\.|KG|OHG|SE|gGmbH|UG|Ltd\\.|Inc\\.|S\\.?A\\.?|Co\\. ?KG)(?=\\W|$)",
          "score": 0.85
        }
      ],
      "context": ["firma", "unternehmen", "arbeitgeber", "gesellschaft"]
    },
    {
      "name": "DE_OrgInstitution",
      "entity_type": "ORGANIZATION",
      "description": "German institutional names with optional prefix",
      "patterns": [
        {
          "name": "org_institution_with_suffix",
          "regex": "(?:[A-ZÄÖÜ][\\w\\u00C0-\\u024F]+ ){0,3}(?:Institut|Verein|Stiftung|Verband|Akademie|Zentrum|Amt|Behörde|Ministerium) (?:für|der|des|zu) [A-ZÄÖÜ][\\w\\u00C0-\\u024F \\-]{2,50}?(?:GmbH|mbH|AG|e\\.? ?V\\.|KG|OHG|SE|gGmbH|UG)\\b",
          "score": 0.9
        },
        {
          "name": "org_institution_no_suffix",
          "regex": "[A-ZÄÖÜ][\\w\\u00C0-\\u024F]+(?: [A-ZÄÖÜ][\\w\\u00C0-\\u024F]+)* (?:Institut|Verein|Stiftung|Verband|Akademie|Zentrum|Amt|Behörde|Ministerium) (?:für|der|des|zu) [A-ZÄÖÜ][\\w\\u00C0-\\u024F]+(?:[ ][A-ZÄÖÜ][\\w\\u00C0-\\u024F]+)*",
          "score": 0.75
        }
      ],
      "context": ["firma", "unternehmen", "arbeitgeber"]
    }
  ],

  "false_positive_denylist": {
    "_comment": "Terms that spaCy frequently misclassifies. Entities matching these exactly are removed.",
    "terms": [
      "Mobil", "Monitoring", "Grafana", "Nagios", "Icinga", "Webhosting",
      "Berichtslinie", "Sozialversicherungsnr", "Personalausweis-Nr",
      "Incident-Response", "Incident-Response-Prozesse",
      "Betrieb und Monitoring", "Aufbau eines Monitoring",
      "Webhosting-Plattform", "On-Premises", "Active Directory",
      "Datev", "OTRS", "Sophos", "Veeam", "VMware", "Cisco",
      "Apache", "Nginx", "MySQL", "Azure", "Intune", "Wazuh",
      "Response", "Prozesse", "Compliance", "Migration",
      "Implementierung", "Administration", "Konfiguration",

      "Telefon", "Personal-Nr", "Personal-Nr.", "Headcount", "Avg",
      "Krankenquote", "Fluktuation", "Notfall-Tel", "Notfall-Tel.",
      "Schulungstage", "Steuer-ID", "Anorganik", "Key",
      "Laborantin", "Systemadministrator", "Abteilungsleitung",
      "Kostenstelle", "Budgetauslastung", "Kundenzufriedenheit",
      "Zielerreichung", "Eintrittsdatum", "Geburtsdatum",
      "Steuerklasse", "Familienstand", "Staatsangehörigkeit",
      "Führerschein", "Fachinformatiker", "Systemintegration",
      "Dipl.-Kfm", "Dipl.-Kfm.",
      "Analytik", "Mikrobiologie", "Sensorik", "Controlling",
      "Probenvorbereitung", "Qualitätsmanagement", "Digitalisierung"
    ]
  },

  "entity_dedup": {
    "_comment": "When entities overlap, higher confidence wins. Priority breaks ties (lower = preferred).",
    "type_priority": {
      "EMAIL_ADDRESS": 0,
      "IBAN_CODE": 0,
      "CREDIT_CARD": 0,
      "IP_ADDRESS": 0,
      "URL": 0,
      "DE_TAX_ID": 1,
      "DE_SOCIAL_SECURITY": 1,
      "DE_ID_CARD": 1,
      "US_SSN": 1,
      "MEDICAL_LICENSE": 1,
      "PHONE_NUMBER": 2,
      "LOCATION": 3,
      "ORGANIZATION": 4,
      "PERSON": 5
    }
  }
}
